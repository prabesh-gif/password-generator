import random
import string

print("=" * 40)
print("      PASSWORD GENERATOR")
print("=" * 40)

length = int(input("Password Length: "))

characters = string.ascii_letters + string.digits + "!@#$%^&*()_+-="

password = ''.join(random.choice(characters) for _ in range(length))

print("\nGenerated Password:")
print(password)
